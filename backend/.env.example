# ---- Core ----
# Postgres connection (docker-compose provides this by default)
DATABASE_URL=postgresql+psycopg://panpay:panpay@localhost:5432/panpay

# Secret used to sign dashboard JWT sessions. CHANGE in production.
JWT_SECRET=dev-change-me-to-a-long-random-string

# How long a dashboard login stays valid (minutes)
JWT_EXPIRE_MINUTES=720

# LINE Messaging API (optional). Access token = push messages; channel secret =
# verify inbound webhook (Webhook URL: https://<domain>/api/line/webhook)
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# Platform admin bootstrap: if both are set and no admin exists yet, the first
# admin is created automatically on startup. Prefer `python create_admin.py`.
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=

# Public base URL of the frontend (used to build checkout_url)
CHECKOUT_BASE_URL=http://localhost:5173

# CORS: comma separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173

# ---- Slip verification provider ----
# Provider: "dev" (local testing, no bank), "slipok", "easyslip", or "slip2go".
SLIP_PROVIDER=dev

# SlipOK credentials (https://slipok.com) — required when SLIP_PROVIDER=slipok
SLIPOK_API_KEY=
SLIPOK_BRANCH_ID=

# EasySlip credentials (https://easyslip.com) — required when SLIP_PROVIDER=easyslip
EASYSLIP_API_KEY=

# Slip2Go credentials (https://slip2go.com) — required when SLIP_PROVIDER=slip2go
SLIP2GO_BASE_URL=https://connect.slip2go.com
SLIP2GO_SECRET_KEY=
SLIP2GO_CHECK_DUPLICATE=true

# In dev provider, automatically accept a submitted slip if the amount matches.
# Set to false to require an explicit trans_ref.
DEV_AUTO_VERIFY=true

# ---- Subscription renewals ----
# Days past a membership's period end before it is marked expired.
SUBSCRIPTION_GRACE_DAYS=3
# Run the renewal job inside the API process (single instance only). For multi-instance
# deploys, leave false and run `python -m app.jobs` from cron / a k8s CronJob instead.
RUN_SCHEDULER=false
SCHEDULER_INTERVAL_HOURS=24

# ---- Member notifications ----
# Email via SMTP (leave SMTP_HOST blank to just log notifications instead of sending).
# Brevo free tier (300/day): host smtp-relay.brevo.com, user = your Brevo login email,
# password = an SMTP key from Brevo > SMTP & API. FROM must be a verified sender.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=PanPay <no-reply@panpay.local>
SMTP_TLS=true
# SMS via a generic HTTP gateway: POST {to, message} with optional Bearer key.
SMS_API_URL=
SMS_API_KEY=
# LINE Messaging API (free within quota). Channel access token from the LINE Developers
# console (Messaging API channel). The member's LINE userId (Uxxxx) is stored per subscription.
LINE_CHANNEL_ACCESS_TOKEN=
